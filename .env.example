# ── Pipedrive ────────────────────────────────────────────────────────────────
# When running with LibreChat: leave this commented out.
# Each user sets their own token in LibreChat UI (Settings → API Keys).
# LibreChat forwards it as the x-pipedrive-token header automatically.
#
# For stdio mode (Claude Desktop / npx) or a shared fallback, uncomment:
# PIPEDRIVE_API_TOKEN=your_pipedrive_api_token_here

# ── MCP server ───────────────────────────────────────────────────────────────
# Port the SSE server listens on inside the container (default: 3000)
# Omit PORT entirely to fall back to stdio transport (Claude Desktop / npx)
PORT=8020

# Host port mapped for local debugging (default: 8020)
MCP_PORT=8020

# ── LibreChat network ────────────────────────────────────────────────────────
# Docker network shared with LibreChat.
# Run: docker network ls   to find the correct name.
# Defaults to librechat-net
LIBRECHAT_NETWORK=librechat_librechat-net

# ── Optional overrides ───────────────────────────────────────────────────────
# PIPEDRIVE_READ_ONLY=false
# PIPEDRIVE_TOOLSETS=deals,leads,persons,organizations,activities,notes,search
# LOG_LEVEL=info
